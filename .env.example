# ========================================
# 🏪 OmniStore - Configuração para MEIs
# ========================================
#
# 📖 GUIA RÁPIDO:
# 1. Copie este arquivo: cp .env.example .env
# 2. Mude as senhas marcadas com ⚠️ OBRIGATÓRIO
# 3. Configure gateways de pagamento (opcional no início)
# 4. Execute: docker-compose up -d
#
# 💡 Dica: Use 'openssl rand -base64 32' para gerar senhas fortes
#
# ========================================

# ========================================
# 🗄️ BANCO DE DADOS (MongoDB)
# ========================================
# Onde seus produtos, pedidos e clientes ficam salvos
#
# Para Docker Compose (padrão): use 'mongo:27017'
# Para instalação local: use 'localhost:27017'
# ⚠️ IMPORTANTE: MUDE 'senha_forte_aqui' por uma senha real!
MONGODB_URI=mongodb://admin:senha_forte_aqui@mongo:27017
MONGODB_DB_NAME=omnistore

# Se rodar localmente sem Docker:
# MONGODB_URI_LOCAL=mongodb://localhost:27017


# ========================================
# ⚡ CACHE (Redis)
# ========================================
# Deixa sua API mais rápida guardando dados temporários
#
# Para Docker Compose: redis://redis:6379
# Para instalação local: redis://localhost:6379
REDIS_URL=redis://redis:6379/0


# ========================================
# 📦 ARMAZENAMENTO DE IMAGENS (MinIO / S3)
# ========================================
# Onde as fotos dos produtos são guardadas
#
# ⚠️ MUDE estas senhas em produção!
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=MUDE_ESTA_SENHA_AQUI_PRODUCAO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=MUDE_ESTA_SENHA_AQUI_PRODUCAO

# Nome do "bucket" (pasta) onde fotos ficam:
S3_BUCKET=products


# ========================================
# 💳 MERCADO PAGO (Gateway de Pagamento)
# ========================================
# Como obter suas credenciais:
# 1. Acesse: https://www.mercadopago.com.br/developers/panel/app
# 2. Crie uma aplicação
# 3. Vá em "Credenciais" > "Credenciais de produção"
#
# 🧪 Para testes, use as credenciais de TEST
# 🚀 Para vendas reais, use as credenciais de PRODUÇÃO

# Chave pública (aparece no frontend se necessário)
MERCADO_PAGO_PUBLIC_KEY=TEST-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# Access Token (NUNCA exponha publicamente!)
MERCADO_PAGO_ACCESS_TOKEN=TEST-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# Webhook Secret (opcional, para validar notificações)
MERCADO_PAGO_WEBHOOK_SECRET=seu_segredo_webhook

# URL que o Mercado Pago vai chamar quando pagamento for confirmado
# ⚠️ Mude 'api.sualoja.com.br' pelo seu domínio real
MERCADO_PAGO_NOTIFICATION_URL=https://api.sualoja.com.br/api/webhooks/mercadopago

# Para onde o cliente vai após finalizar compra
CHECKOUT_SUCCESS_URL=https://sualoja.com.br/sucesso
CHECKOUT_FAILURE_URL=https://sualoja.com.br/erro
CHECKOUT_PENDING_URL=https://sualoja.com.br/pendente


# ========================================
# 💰 ASAAS (Gateway de Pagamento Alternativo)
# ========================================
# Como obter sua API Key:
# 1. Acesse: https://www.asaas.com/
# 2. Faça cadastro
# 3. Vá em "Integrações" > "API Key"
#
# 🧪 Sandbox (testes): ASAAS_SANDBOX=true
# 🚀 Produção: ASAAS_SANDBOX=false

ASAAS_API_KEY=$aact_hmlg_XXXXXXXX-XXXXXXXX-XXXXXXXX-XXXXXXXX
ASAAS_SANDBOX=true
ASAAS_SANDBOX_URL=https://sandbox.asaas.com/api/v3
ASAAS_URL=https://www.asaas.com/api/v3

# Webhook Secret para validar notificações
ASAAS_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXX


# ========================================
# 🔐 SEGURANÇA
# ========================================
# Token de administrador para acessar API
# ⚠️ OBRIGATÓRIO: Mude para uma senha forte aleatória!
# Use este header em requisições: Authorization: Bearer SEU_TOKEN_AQUI
ADMIN_TOKEN=CRIE_UMA_SENHA_MUITO_FORTE_ALEATORIA_AQUI


# ========================================
# 🌐 APLICAÇÃO
# ========================================
# Porta onde a API vai rodar (padrão: 8080)
APP_PORT=8080

# Ambiente (development ou production)
APP_ENV=development

# URL base da sua API (usado em webhooks)
APP_URL=http://localhost:8080


# ========================================
# 📧 EMAIL (Opcional - Para Futuro)
# ========================================
# Para enviar emails de confirmação de pedido
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu-email@gmail.com
# SMTP_PASS=sua-senha-ou-app-password
# SMTP_FROM=noreply@sualoja.com.br


# ========================================
# 📊 LOGS E MONITORAMENTO (Opcional)
# ========================================
# Nível de log (trace, debug, info, warn, error)
LOG_LEVEL=info

# Formato de log (json ou pretty)
LOG_FORMAT=pretty


# ========================================
# 🚀 PRONTO!
# ========================================
# Depois de configurar este arquivo:
# 1. Salve como '.env' (sem .example)
# 2. Execute: docker-compose up -d
# 3. Acesse: http://localhost:8080/health
#
# ✅ Deve retornar: {"status":"ok"}
#
# 📚 Documentação completa: README.md
# 🆘 Problemas? Veja: SIMPLE_SETUP.md
# ========================================
